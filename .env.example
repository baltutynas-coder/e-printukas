# ============================================
# e.printukas.lt — aplinkos kintamieji
# Kopijuok šį failą kaip .env ir užpildyk reikšmes
# ============================================

# Serveris
PORT=4000
NODE_ENV=development

# Duomenų bazė (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/eprintukas?schema=public"

# JWT (admin autentifikacija)
JWT_SECRET="pakeisk-i-ilga-slapta-reiksme-min-32-simboliai"
JWT_EXPIRES_IN="7d"

# Stripe (mokėjimai) — gausi iš stripe.com/dashboard
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Cloudinary (nuotraukos) — gausi iš cloudinary.com/console
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# El. paštas (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="info@e.printukas.lt"

# Frontend URL (CORS)
FRONTEND_URL="http://localhost:3000"
