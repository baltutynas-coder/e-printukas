// Prisma schema — e.printukas.lt duomenų bazės struktūra
//
// Sprint A pakeitimai:
//   - Pridėtas Supplier enum (ROLY | STAMINA) — produkto kilmė
//   - Pridėtas Product.supplier laukas (default: ROLY)
//   - Pridėtas Tag modelis (OCCASION | INDUSTRY tipo žymėjimas)
//   - Pridėta ProductTag jungiamoji lentelė (many-to-many)
//   - Product.tags ryšys į ProductTag

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ADMIN VARTOTOJAS
// ============================================
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("admins")
}

enum Role {
  ADMIN
  MANAGER
}

// ============================================
// KATEGORIJOS
// ============================================
model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  image    String?
  parentId String?    @map("parent_id")
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("categories")
}

// ============================================
// PRODUKTAI
// ============================================
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  comparePrice Decimal? @db.Decimal(10, 2) @map("compare_price")
  sku         String?  @unique
  published   Boolean  @default(false)
  gender      Gender   @default(UNISEX)

  // Sprint A: Tiekėjas (Roly esami / Stamina nauji)
  supplier    Supplier @default(ROLY)

  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  images     ProductImage[]
  variants   ProductVariant[]
  orderItems OrderItem[]

  // Sprint A: Tag'ai (progoms ir pramonėms)
  tags       ProductTag[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("products")
}

enum Gender {
  MEN
  WOMEN
  UNISEX
  CHILDREN
}

// Sprint A — produkto tiekėjas
enum Supplier {
  ROLY     // 245 esami drabužiai
  STAMINA  // Dovanos, aksesuarai (importuosim)
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0) @map("sort_order")
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("product_images")
}

model ProductVariant {
  id        String  @id @default(cuid())
  color     String?
  colorHex  String? @map("color_hex")
  size      String?
  stock     Int     @default(0)
  sku       String? @unique
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  @@map("product_variants")
}

// ============================================
// SPRINT A — TAG'AI (progos ir pramonė)
// ============================================
//
// Vienas produktas → daug tag'ų (per ProductTag)
// Vienas tag'as → daug produktų (per ProductTag)
//
// Naudojimas:
//   - OCCASION tag'ai: „verslo-dovanos", „kaledos", „welcome-kit"
//   - INDUSTRY tag'ai: „horeca", „it-finansai", „statyba-pramone"
//
// SEO landing puslapiai automatiškai generuojami iš tag'ų:
//   /pagal-proga/verslo-dovanos
//   /pagal-pramone/horeca
// ============================================

model Tag {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  type        TagType
  description String?  @db.Text   // Trumpas SEO description (~155 char)
  heroText    String?  @map("hero_text") @db.Text  // Landing puslapio H1+intro
  sortOrder   Int      @default(0) @map("sort_order")

  products    ProductTag[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tags")
}

enum TagType {
  OCCASION   // Pagal progą (verslo dovanos, kalėdos, welcome kit...)
  INDUSTRY   // Pagal pramonę (HORECA, IT, statyba...)
}

// Jungiamoji lentelė many-to-many ryšiui
model ProductTag {
  productId String   @map("product_id")
  tagId     String   @map("tag_id")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([productId, tagId])
  @@index([tagId])
  @@map("product_tags")
}

// ============================================
// UŽSAKYMAI
// ============================================
model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique @map("order_number")
  status        OrderStatus @default(PENDING)
  customerEmail String @map("customer_email")
  customerName  String @map("customer_name")
  customerPhone String? @map("customer_phone")
  shippingAddress String @map("shipping_address") @db.Text
  shippingCity    String @map("shipping_city")
  shippingZip     String @map("shipping_zip")
  shippingCountry String @default("LT") @map("shipping_country")
  subtotal     Decimal @db.Decimal(10, 2)
  shippingCost Decimal @default(0) @db.Decimal(10, 2) @map("shipping_cost")
  total        Decimal @db.Decimal(10, 2)
  stripePaymentId String? @map("stripe_payment_id")
  paidAt          DateTime? @map("paid_at")
  items     OrderItem[]
  notes     String?     @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  orderId   String  @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  variantId String? @map("variant_id")
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  @@map("order_items")
}
